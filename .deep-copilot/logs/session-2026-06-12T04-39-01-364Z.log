[2026-06-12T04:45:10.205Z] [TOOL_CALL] {"id":"call_00_FwcrJOvRECbZwxSArA0f9699","name":"write_file","args":{"content":"#!/usr/bin/env python3\n\"\"\"\nextnav_to_vision_pose.py — 外部导航数据桥接到飞控 ENU 坐标系\n\n将外部里程计 (Odin SLAM) 从自身坐标系变换到飞控 ENU 坐标系后，同时发布:\n  /mavros/vision_pose/pose   (PoseStamped, 送飞控 EKF 融合)\n  /extnav/pose_fcu           (PoseStamped, 供控制器使用)\n  /extnav/velocity_fcu       (TwistStamped, 供控制器使用)\n\n外参含义: Odin 自身在飞控 ENU 坐标系下的位姿\n  odin_x / odin_y / odin_z                        — Odin 原点在 FCU 下的位置 (米)\n  odin_roll_deg / odin_pitch_deg / odin_yaw_deg   — Odin 坐标轴相对 FCU 的 ZYX 欧拉角 (度)\n\n变换模型:\n  姿态 (先算): q_fcu = q_R * q_odin * inv(q_R)\n  位置:       p_fcu = p_odin + T - R_fcu @ T\n  速度:       v_fcu = v_odin - R_fcu @ (Omega × T)\n\n其中 q_R / R 由固定外参决定, R_fcu 来自当前姿态 q_fcu 构造的旋转矩阵\n\"\"\"\n\nimport rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import PoseStamped, TwistStamped\nfrom nav_msgs.msg import Odometry\nimport math\nimport numpy as np\n\n\ndef euler_to_quaternion(roll, pitch, yaw):\n    \"\"\"ZYX 欧拉角 → 四元数\"\"\"\n    cr = math.cos(roll / 2.0)\n    sr = math.sin(roll / 2.0)\n    cp = math.cos(pitch / 2.0)\n    sp = math.sin(pitch / 2.0)\n    cy = math.cos(yaw / 2.0)\n    sy = math.sin(yaw / 2.0)\n\n    w = cr * cp * cy + sr * sp * sy\n    x = sr * cp * cy - cr * sp * sy\n    y = cr * sp * cy + sr * cp * sy\n    z = cr * cp * sy - sr * sp * cy\n    return (x, y, z, w)\n\n\ndef multiply_quaternions(q1_xyzw, q2_xyzw):\n    \"\"\"四元数乘法: q1 * q2, 输入为 (x,y,z,w) 元组\"\"\"\n    x1, y1, z1, w1 = q1_xyzw\n    x2, y2, z2, w2 = q2_xyzw\n    w = w1 * w2 - x1 * x2 - y1 * y2 - z1 * z2\n    x = w1 * x2 + x1 * w2 + y1 * z2 - z1 * y2\n    y = w1 * y2 - x1 * z2 + y1 * w2 + z1 * x2\n    z = w1 * z2 + x1 * y2 - y1 * x2 + z1 * w2\n    return (x, y, z, w)\n\n\ndef quaternion_to_rotation_matrix(q_xyzw):\n    \"\"\"四元数 → 3×3 旋转矩阵\"\"\"\n    x, y, z, w = q_xyzw\n    xx, yy, zz = x * x, y * y, z * z\n    xy, xz, yz = x * y, x * z, y * z\n    wx, wy, wz = w * x, w * y, w * z\n    return np.array([\n        [1.0 - 2.0*(yy + zz), 2.0*(xy - wz),       2.0*(xz + wy)],\n        [2.0*(xy + wz),       1.0 - 2.0*(xx + zz), 2.0*(yz - wx)],\n        [2.0*(xz - wy),       2.0*(yz + wx),        1.0 - 2.0*(xx + yy)],\n    ])\n\n\nclass FlexibleBridge(Node):\n\n    def __init__(self):\n        super().__init__('extnav_to_vision_pose')\n\n        # ---- 输入/输出话题 ----\n        self.declare_parameter('input_topic', '/odin1/odometry_highfreq')\n        self.declare_parameter('vision_pose_topic', '/mavros/vision_pose/pose')\n        self.declare_parameter('pose_fcu_topic', '/extnav/pose_fcu')\n        self.declare_parameter('vel_fcu_topic', '/extnav/velocity_fcu')\n        self.declare_parameter('input_type', 'odometry')\n        self.declare_parameter('rate_hz', 100.0)\n\n        # ---- Odin 在 FCU 坐标系下的位姿 (手动给定) ----\n        self.declare_parameter('odin_roll_deg', 0.0)\n        self.declare_parameter('odin_pitch_deg', 0.0)\n        self.declare_parameter('odin_yaw_deg', 0.0)\n        self.declare_parameter('odin_x', 0.0)\n        self.declare_parameter('odin_y', 0.0)\n        self.declare_parameter('odin_z', 0.0)\n\n        input_topic = self.get_parameter('input_topic').value\n        vis_topic = self.get_parameter('vision_pose_topic').value\n        pose_fcu_topic = self.get_parameter('pose_fcu_topic').value\n        vel_fcu_topic = self.get_parameter('vel_fcu_topic').value\n        input_type = self.get_parameter('input_type').value\n        rate_hz = self.get_parameter('rate_hz').value\n\n        roll_deg = self.get_parameter('odin_roll_deg').value\n        pitch_deg = self.get_parameter('odin_pitch_deg').value\n        yaw_deg = self.get_parameter('odin_yaw_deg').value\n\n        self.roll_rad = roll_deg * math.pi / 180.0\n        self.pitch_rad = pitch_deg * math.pi / 180.0\n        self.yaw_rad = yaw_deg * math.pi / 180.0\n        self.tx = self.get_parameter('odin_x').value\n        self.ty = self.get_parameter('odin_y').value\n        self.tz = self.get_parameter('odin_z').value\n\n        # 旋转四元数 q_R (固定外参, 供姿态基变换使用)\n        self.q_R = euler_to_quaternion(self.roll_rad, self.pitch_rad, self.yaw_rad)\n\n        # ---- 发布器 ----\n        self.vis_pub = self.create_publisher(PoseStamped, vis_to…(+4640 chars)","path":"/home/xld/vrpn_mavros/src/extnav_bridge/extnav_bridge/extnav_to_vision_pose.py"}}
