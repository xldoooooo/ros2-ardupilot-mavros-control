n + T - q_fcu @ T\n\n        # 速度: v_fcu = v_odin - R * (Omega × T)\n        v_odin = np.array([vx, vy, vz])\n        omega = np.array([wx, wy, wz])\n        lever_arm_vel = np.cross(omega, T)  # Omega × T\n        v_fcu = v_odin - R @ lever_arm_vel\n\n        \n\n        return p_fcu, v_fcu, q_fcu","path":"/home/xld/vrpn_mavros/src/extnav_bridge/extnav_bridge/extnav_to_vision_pose.py"}}
