[2026-06-12T01:00:57.057Z] [TOOL_RESULT] {"id":"call_00_nZlOv5L69A4GtA1DPawy2061","name":"read_file","elapsed_ms":4,"ok":true,"output":"#!/usr/bin/env python3\nimport rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import PoseStamped\nfrom nav_msgs.msg import Odometry\n\nclass FlexibleBridge(Node):\n    def __init__(self):\n        super().__init__('vrpn_to_vision_pose')\n        self.declare_parameter('input_topic', '/odin1/odometry_highfreq')\n        self.declare_parameter('output_topic', '/mavros/vision_pose/pose')\n        self.declare_parameter('input_type', 'odometry')\n        self.declare_parameter('rate_hz', 100.0)          # 目标发布频率（可调）\n        \n        input_topic = self.get_parameter('input_topic').value\n        output_topic = self.get_parameter('output_topic').value\n        input_type = self.get_parameter('input_type').value\n        rate_hz = self.get_parameter('rate_hz').value\n        \n        self.pub = self.create_publisher(PoseStamped, output_topic, 10)\n        self.latest_msg = None\n        \n        if input_type == 'odometry':\n            self.sub = self.create_subscription(Odometry, input_topic, self.cache_callback, 10)\n        else:\n            self.sub = self.create_subscription(PoseStamped, input_topic, self.cache_pose_callback, 10)\n        \n        # 定时器发布\n        self.timer = self.create_timer(1.0 / rate_hz, self.timer_callback)\n        self.get_logger().info(f'Bridge started: {input_topic} -> {output_topic} at {rate_hz} Hz')\n    \n    def cache_callback(self, msg: Odometry):\n        self.latest_msg = msg\n    \n    def cache_pose_callback(self, msg: PoseStamped):\n        self.latest_msg = msg\n    \n    def timer_callback(self):\n        if self.latest_msg is None:\n            return\n        out = PoseStamped()\n        # 保留原始时间戳（利于飞控EKF）\n        out.header.stamp = self.latest_msg.header.stamp\n        if out.header.stamp.sec == 0 and out.header.stamp.nanosec == 0:\n            out.header.stamp = self.get_clock().now().to_msg()\n        out.header.frame_id = self.latest_msg.header.frame_id or 'map'\n        \n        if isinstance(self.latest_msg, Odometry):\n            out.pose = self."}
