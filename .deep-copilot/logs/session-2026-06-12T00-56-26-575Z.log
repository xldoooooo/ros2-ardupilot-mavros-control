erniond q_yaw(cos(g_odin_T.yaw_rad / 2.0), 0, 0, sin(g_odin_T.yaw_rad / 2.0));\n+    Eigen::Quaterniond q_odin(g_odin_pose.w, g_odin_pose.x, g_odin_pose.y, g_odin_pose.z);\n+    Eigen::Quaterniond q_fcu = q_yaw * q_odin;\n+\n+    localpose.w = q_fcu.w();\n+    localpose.x = q_fcu.x();\n+    localpose.y = q_fcu.y();\n+    localpose.z = q_fcu.z();\n+}\n+\n //---------------------回调函数区域---------------------\n xyz_d_def localposition;\n QuaternionTypedef localpose;\n void toEulerAngle(const Eigen::Quaterniond &q, double &roll, double &pitch, double &yaw);\n double calculate_VectorAngular_x(xyz_d_def vector_major);\n \n+// 接收 Odin 高频里程计的回调函数 (Odin 坐标系)\n+void odinOdomCallback(const nav_msgs::msg::Odometry::ConstPtr &msg) {\n+    g_odin_position.x = msg->pose.pose.position.x;\n+    g_odin_position.y = msg->pose.pose.position.y;\n+    g_odin_position.z = msg->pose.pose.position.z;\n+\n+    g_odin_pose.x = msg->pose.pose.orientation.x;\n+    g_odin_pose.y = msg->pose.pose.orientation.y;\n+    g_odin_pose.z = msg->pose.pose.orientation.z;\n+    g_odin_pose.w = msg->pose.pose.orientation.w;\n+\n+    g_odin_velocity.x = msg->twist.twist.linear.x;\n+    g_odin_velocity.y = msg->twist.twist.linear.y;\n+    g_odin_velocity.z = msg->twist.twist.linear.z;\n+\n+    if (!g_odin_received) {\n+        g_odin_received = true;\n+    }\n+\n+    // 如果已标定且启用 Odin，立即更新 localposition/localvelocity\n+    if (g_odin_T.calibrated && g_use_odin) {\n+        applyOdinTransform();\n+    }\n+}\n+\n //接收当前位姿的回调函数\n void poseCallback(const geometry_msgs::msg::PoseStamped::ConstPtr &msg){\n+    // 如果正在使用 Odin 高频里程计，MAVROS pose 仅用于轨迹显示和标定\n+    if (g_odin_T.calibrated && g_use_odin && g_odin_received) {\n+        // MAVROS pose 仅用于标定后的轨迹记录 (curTrajectory)\n+        // 控制用的 localposition/localpose/localvelocity 由 Odin 回调更新\n+    } else {\n     localposition.x = msg->pose.position.x ;\n     localposition.y = msg->pose.position.y ;    \n     localposition.z = msg->pose.position.z ;  \n@@ -222,6 +297,7 @@\n