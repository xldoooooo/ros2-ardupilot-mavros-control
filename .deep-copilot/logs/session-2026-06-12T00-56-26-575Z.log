[2026-06-12T01:08:02.717Z] [TOOL_CALL] {"id":"call_00_qdKuAS6dE805DiP4Wl9s6547","name":"str_replace_in_file","args":{"path":"/home/xld/ros2-ardupilot-mavros-control/src/guided_sim/src/keyboard_vel_controller.cpp","old_string":"//---------------------发送数据消息接口类型区域结束---------------------\n\n//---------------------回调函数区域---------------------\nxyz_d_def localposition;\nQuaternionTypedef localpose;\nvoid toEulerAngle(const Eigen::Quaterniond &q, double &roll, double &pitch, double &yaw);\ndouble calculate_VectorAngular_x(xyz_d_def vector_major);\n\n//接收当前位姿的回调函数\nvoid poseCallback(const geometry_msgs::msg::PoseStamped::ConstPtr &msg){","new_string":"//---------------------发送数据消息接口类型区域结束---------------------\n\n//--------------------- Odin → FCU 坐标变换参数 ---------------------\n// 变换模型: p_fcu = R_yaw * p_odin + T_offset\n//           v_fcu = R_yaw * v_odin\n// 其中 R_yaw 是绕 Z 轴的旋转矩阵 (yaw 对齐)\nstruct OdinTransform {\n    double tx = 0.0;          // X 方向平移 (m)\n    double ty = 0.0;          // Y 方向平移 (m)\n    double tz = 0.0;          // Z 方向平移 (m)\n    double yaw_rad = 0.0;     // 绕 Z 轴旋转角 (rad)\n    bool   calibrated = false;// 是否已标定\n};\nOdinTransform g_odin_T;       // Odin→FCU 变换参数\nbool g_odin_auto_calib = true;// 启动时自动标定\nbool g_use_odin = true;       // 是否启用 Odin 高频里程计\n\n// Odin 高频里程计的最新数据 (Odin 坐标系下)\nxyz_d_def      g_odin_position;     // Odin frame position\nQuaternionTypedef g_odin_pose;      // Odin frame orientation\nxyz_d_def      g_odin_velocity;     // Odin frame linear velocity\nbool           g_odin_received = false;\n\n//---------------------回调函数区域---------------------\nxyz_d_def localposition;\nQuaternionTypedef localpose;\nvoid toEulerAngle(const Eigen::Quaterniond &q, double &roll, double &pitch, double &yaw);\ndouble calculate_VectorAngular_x(xyz_d_def vector_major);\n\n// 应用 Odin→FCU 坐标变换，更新 localposition/localpose/localvelocity\nvoid applyOdinTransform() {\n    if (!g_odin_received || !g_odin_T.calibrated) return;\n\n    double cy = cos(g_odin_T.yaw_rad);\n    double sy = sin(g_odin_T.yaw_rad);\n\n    // 位置: p_fcu = R_yaw * p_odin + T\n    localposition.x = cy * g_odin_position.x - sy * g_odin_position.y + g_odin_T.tx;\n    localposition.y = sy * g_odin_position.x + cy * g_odin_position.y + g_odin_T.ty;\n    localposition.z = g_odin_position.z + g_odin_T.tz;\n\n    // 速度: v_fcu = R_yaw * v_odin\n    localvelocity.x = cy * g_odin_velocity.x - sy * g_odin_velocity.y;\n    localvelocity.y = sy * g_odin_velocity.x + cy * g_odin_velocity.y;\n    localvelocity.z = g_odin_velocity.z;\n\n    // 姿态: q_fcu = q_yaw * q_odin\n    Eigen::Quaterniond q_yaw(cos(g_odin_T.yaw_rad / 2.0), 0, 0, sin(g_odin_T.yaw_rad / 2.0));\n    Eigen::Quaterniond q_odin(g_odin_pose.w, g_odin_pose.x, g_odin_pose.y, g_odin_pose.z);\n    Eigen::Quaterniond q_fcu = q_yaw * q_odin;\n\n    localpose.w = q_fcu.w();\n    localpose.x = q_fcu.x();\n    localpose.y = q_fcu.y();\n    localpose.z = q_fcu.z();\n}\n\n// 接收 Odin 高频里程计的回调函数 (Odin 坐标系)\nvoid odinOdomCallback(const nav_msgs::msg::Odometry::ConstPtr &msg) {\n    g_odin_position.x = msg->pose.pose.position.x;\n    g_odin_position.y = msg->pose.pose.position.y;\n    g_odin_position.z = msg->pose.pose.position.z;\n\n    g_odin_pose.x = msg->pose.pose.orientation.x;\n    g_odin_pose.y = msg->pose.pose.orientation.y;\n    g_odin_pose.z = msg->pose.pose.orientation.z;\n    g_odin_pose.w = msg->pose.pose.orientation.w;\n\n    g_odin_velocity.x = msg->twist.twist.linear.x;\n    g_odin_velocity.y = msg->twist.twist.linear.y;\n    g_odin_velocity.z = msg->twist.twist.linear.z;\n\n    if (!g_odin_received) {\n        g_odin_received = true;\n    }\n\n    // 如果已标定且启用 Odin，立即更新 localposition/localvelocity\n    if (g_odin_T.calibrated && g_use_odin) {\n        applyOdinTransform();\n    }\n}\n\n//接收当前位姿的回调函数 (MAVROS, 仅用于轨迹显示和标定)\nvoid poseCallback(const geometry_msgs::msg::PoseStamped::ConstPtr &msg){\n    // 如果正在使用 Odin 高频里程计，MAVROS pose 不覆盖 localposition/localpose\n    // 控制用的 localposition/localpose 由 Odin 回调通过 applyOdinTransform() 更新\n    if (!(g_odin_T.calibrated && g_use_odin && g_odin_received)) {\n        localposition.x = msg->pose.position.x ;\n        localposition.y = msg->pose.position.y ;    \n        localposition.z = msg->pose.position.z ;\n\n        localpose.x = msg->pose.orientation.x ;\n        localpose.y = msg->pose.orientation.y ; \n        localpose.z = msg->pose.orientation.z ;\n        localpose.w = msg->pose.orientation.w ;\n    }"}}
