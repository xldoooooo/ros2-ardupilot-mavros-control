ic} -> {pose_out} at {rate_hz} Hz'\n            f'{\" (auto-calib enabled)\" if self.auto_calib else \"\"}')\n\n    def odin_callback(self, msg: Odometry):\n        self.latest_odom = msg\n\n    def mavros_callback(self, msg: PoseStamped):\n        \"\"\"自动标定: 收到第一帧 MAVROS 和 Odin 数据后计算偏移\"\"\"\n        if self.calibrated:\n            r…(+3245 chars)"}}
