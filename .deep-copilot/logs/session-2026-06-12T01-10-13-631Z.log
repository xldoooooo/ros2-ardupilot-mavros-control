[2026-06-12T01:38:42.187Z] [TOOL_CALL] {"id":"call_00_KaZpzT9JyGjtzM92kluV9613","name":"write_file","args":{"content":"#!/usr/bin/env python3\n\"\"\"\nvrpn_to_vision_pose.py — Odin SLAM 里程计桥接到飞控 ENU 坐标系\n\n将 Odin SLAM 坐标系下的里程计变换到飞控 ENU 坐标系后，同时发布:\n  /mavros/vision_pose/pose   (PoseStamped, 送飞控 EKF 融合)\n  /mocap/pose_fcu            (PoseStamped, 供控制器使用)\n  /mocap/velocity_fcu        (TwistStamped, 供控制器使用)\n\n变换模型 (ZYX 欧拉角):\n  p_fcu = R * p_odin + T\n  v_fcu = R * v_odin\n  q_fcu = q_R * q_odin\n\n其中 R = Rz(yaw) * Ry(pitch) * Rx(roll), T = (x_offset, y_offset, z_offset)\n\"\"\"\n\nimport rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import PoseStamped, TwistStamped\nfrom nav_msgs.msg import Odometry\nimport math\nimport numpy as np\n\n\ndef euler_to_quaternion(roll, pitch, yaw):\n    \"\"\"ZYX 欧拉角 → 四元数\"\"\"\n    cr = math.cos(roll / 2.0)\n    sr = math.sin(roll / 2.0)\n    cp = math.cos(pitch / 2.0)\n    sp = math.sin(pitch / 2.0)\n    cy = math.cos(yaw / 2.0)\n    sy = math.sin(yaw / 2.0)\n\n    w = cr * cp * cy + sr * sp * sy\n    x = sr * cp * cy - cr * sp * sy\n    y = cr * sp * cy + sr * cp * sy\n    z = cr * cp * sy - sr * sp * cy\n    return (x, y, z, w)\n\n\ndef multiply_quaternions(q1_xyzw, q2_xyzw):\n    \"\"\"四元数乘法: q1 * q2, 输入为 (x,y,z,w) 元组\"\"\"\n    x1, y1, z1, w1 = q1_xyzw\n    x2, y2, z2, w2 = q2_xyzw\n    w = w1 * w2 - x1 * x2 - y1 * y2 - z1 * z2\n    x = w1 * x2 + x1 * w2 + y1 * z2 - z1 * y2\n    y = w1 * y2 - x1 * z2 + y1 * w2 + z1 * x2\n    z = w1 * z2 + x1 * y2 - y1 * x2 + z1 * w2\n    return (x, y, z, w)\n\n\nclass FlexibleBridge(Node):\n\n    def __init__(self):\n        super().__init__('vrpn_to_vision_pose')\n\n        # ---- 输入/输出话题 ----\n        self.declare_parameter('input_topic', '/odin1/odometry_highfreq')\n        self.declare_parameter('vision_pose_topic', '/mavros/vision_pose/pose')\n        self.declare_parameter('pose_fcu_topic', '/mocap/pose_fcu')\n        self.declare_parameter('vel_fcu_topic', '/mocap/velocity_fcu')\n        self.declare_parameter('input_type', 'odometry')\n        self.declare_parameter('rate_hz', 100.0)\n\n        # ---- Odin→FCU 外参 (手动给定) ----\n        self.declare_parameter('roll_offset_deg', 0.0)\n        self.declare_parameter('pitch_offset_deg', 0.0)\n        self.declare_parameter('yaw_offset_deg', 0.0)\n        self.declare_parameter('x_offset', 0.0)\n        self.declare_parameter('y_offset', 0.0)\n        self.declare_parameter('z_offset', 0.0)\n\n        input_topic = self.get_parameter('input_topic').value\n        vis_topic = self.get_parameter('vision_pose_topic').value\n        pose_fcu_topic = self.get_parameter('pose_fcu_topic').value\n        vel_fcu_topic = self.get_parameter('vel_fcu_topic').value\n        input_type = self.get_parameter('input_type').value\n        rate_hz = self.get_parameter('rate_hz').value\n\n        roll_deg = self.get_parameter('roll_offset_deg').value\n        pitch_deg = self.get_parameter('pitch_offset_deg').value\n        yaw_deg = self.get_parameter('yaw_offset_deg').value\n\n        self.roll_rad = roll_deg * math.pi / 180.0\n        self.pitch_rad = pitch_deg * math.pi / 180.0\n        self.yaw_rad = yaw_deg * math.pi / 180.0\n        self.tx = self.get_parameter('x_offset').value\n        self.ty = self.get_parameter('y_offset').value\n        self.tz = self.get_parameter('z_offset').value\n\n        # ---- 预计算旋转矩阵 (ZYX: R = Rz * Ry * Rx) ----\n        cr = math.cos(self.roll_rad)\n        sr = math.sin(self.roll_rad)\n        cp = math.cos(self.pitch_rad)\n        sp = math.sin(self.pitch_rad)\n        cy = math.cos(self.yaw_rad)\n        sy = math.sin(self.yaw_rad)\n\n        # R = Rz(yaw) * Ry(pitch) * Rx(roll)\n        self.R = np.array([\n            [cy * cp, cy * sp * sr - sy * cr, cy * sp * cr + sy * sr],\n            [sy * cp, sy * sp * sr + cy * cr, sy * sp * cr - cy * sr],\n            [-sp,     cp * sr,                cp * cr],\n        ])\n\n        # 旋转四元数 (用于姿态变换)\n        self.q_R = euler_to_quaternion(self.roll_rad, self.pitch_rad, self.yaw_rad)\n\n        # ---- 发布器 ----\n        self.vis_pub = self.create_publisher(PoseStamped, vis_topic, 10)\n        self.pose_fcu_pub = self.create_publisher(PoseStamped, pose_fcu_topic, 10)\n     …(+3833 chars)","path":"/home/xld/vrpn_mavros/src/mocap_bridge/mocap_bridge/vrpn_to_vision_pose.py"}}
