[2026-06-12T02:09:54.219Z] [TOOL_CALL] {"id":"call_00_Bm8TJQ9rO6t0N8l3KDKL9967","name":"str_replace_in_file","args":{"new_string":"    def _apply_transform(self, px, py, pz, vx, vy, vz, qx, qy, qz, qw, wx, wy, wz):\n        \"\"\"将 Odin 坐标系下的位姿/速度/姿态变换到 FCU 坐标系\n        \n        位置: p_fcu = p_odin + T - R * T\n        速度: v_fcu = v_odin - R * (Omega × T)    (杠杆臂补偿)\n        Omega = (wx, wy, wz) 为 Odin 输出的角速度\n        \"\"\"\n        R = self.R\n        T = np.array([self.tx, self.ty, self.tz])\n\n        # 位置: p_fcu = p_odin + T - R * T\n        p_odin = np.array([px, py, pz])\n        p_fcu = p_odin + T - R @ T\n\n        # 速度: v_fcu = v_odin - R * (Omega × T)\n        v_odin = np.array([vx, vy, vz])\n        omega = np.array([wx, wy, wz])\n        lever_arm_vel = np.cross(omega, T)  # Omega × T\n        v_fcu = v_odin - R @ lever_arm_vel\n\n        # 姿态: q_fcu = q_R * q_odin  (TODO: 待确认)\n        q_fcu = multiply_quaternions(self.q_R, (qx, qy, qz, qw))\n\n        return p_fcu, v_fcu, q_fcu","old_string":"    def _apply_transform(self, px, py, pz, vx, vy, vz, qx, qy, qz, qw):\n        \"\"\"对 Odin 坐标系下的位姿/速度/姿态应用 Odin→FCU 变换\"\"\"\n        R = self.R\n\n        # 位置: p_fcu = R * p_odin + T\n        p_fcu = R @ np.array([px, py, pz]) + np.array([self.tx, self.ty, self.tz])\n\n        # 速度: v_fcu = R * v_odin\n        v_fcu = R @ np.array([vx, vy, vz])\n\n        # 姿态: q_fcu = q_R * q_odin\n        q_fcu = multiply_quaternions(self.q_R, (qx, qy, qz, qw))\n\n        return p_fcu, v_fcu, q_fcu","path":"/home/xld/vrpn_mavros/src/extnav_bridge/extnav_bridge/extnav_to_vision_pose.py"}}
