n                \"Odin auto-calib done: T=(%.2f,%.2f,%.2f), yaw_off=%.2f deg\",\n                g_odin_T.tx, g_odin_T.ty, g_odin_T.tz,\n                g_odin_T.yaw_rad * 180.0 / M_PI);\n\n            // 标定后立即更新 localposition/localpose/localvelocity\n            applyOdinTransform();\n        }\n    } else if (g_use_odin && !g_odin_auto_calib) {\n        // 使用 launch 参数的手动变换，直接标记为已标定\n        g_odin_T.calibrated = true;\n        RCLCPP_INFO(rclcpp::get_logger(\"guided_sim\"),\n            \"Odin transform from params: T=(%.2f,%.2f,%.2f), yaw=%.2f deg\",\n            g_odin_T.tx, g_odin_T.ty, g_odin_T.tz,\n            g_odin_T.yaw_rad * 180.0 / M_PI);\n    }\n\n    // ---- 等待 IMU 加速度数据 (如果自动标定已经等过则跳过) ----\n    while ((localacceleration.z == 0) && rclcpp::ok()) {\n        printf(\"wait~~~\\r\\n\");\n        rclcpp::spin_some(node);\n        rate.sleep();\n    }","path":"/home/xld/ros2-ardupilot-mavros-control/src/guided_sim/src/keyboard_vel_controller.cpp"}}
