[2026-06-02T11:41:19.814Z] [TOOL_RESULT] {"id":"call_00_w0Rnv6xMkcHMD1FcAvUX4881","name":"read_file","elapsed_ms":0,"ok":true,"output":"import os\nfrom launch import LaunchDescription\nfrom launch_ros.actions import Node\nfrom ament_index_python.packages import get_package_share_directory\n\n\ndef generate_launch_description():\n    pkg_share = get_package_share_directory('guided_sim')\n\n    keyboard_vel_controller_node = Node(\n        package='guided_sim',\n        executable='keyboard_vel_controller',\n        name='keyboard_vel_controller',\n        output='screen',\n        parameters=[{\n            'ciecle_range': 0.5,\n            'jump_pointnumber': 5.0,\n            'vel_forward_setting': 0.8,\n            'target_x': 0.08,\n            'target_y': 9.0,\n\n            # Position PID\n            'position_X_P': 1.0,\n            'position_X_I': 0.0,\n            'position_X_D': 0.05,\n            'position_Y_P': 1.0,\n            'position_Y_I': 0.0,\n            'position_Y_D': 0.05,\n            'position_Z_P': 1.0,\n            'position_Z_I': 0.0,\n            'position_Z_D': 0.0,\n\n            # Velocity PID\n            'vel_X_P': 1.8,\n            'vel_X_I': 0.0,\n            'vel_X_D': 0.3,\n            'vel_Y_P': 5.0,\n            'vel_Y_I': 0.0,\n            'vel_Y_D': 0.3,\n            'vel_Z_P': 1.0,\n            'vel_Z_I': 0.0,\n            'vel_Z_D': 0.0,\n\n            # Lateral velocity PID\n            'vel_X_T_P': 4.0,\n            'vel_X_T_I': 0.2,\n            'vel_X_T_D': 0.03,\n            'vel_Y_T_P': 4.0,\n            'vel_Y_T_I': 0.2,\n            'vel_Y_T_D': 0.03,\n            'vel_Z_T_P': 0.55,\n            'vel_Z_T_I': 0.2,\n            'vel_Z_T_D': 0.0,\n\n            # Velocity limits\n            'vel_X_limit': 10.0,\n            'vel_Y_limit': 10.0,\n            'vel_Z_limit': 10.0,\n\n            # Attitude limits\n            'roll_limit': 30.0,\n            'pitch_limit': 30.0,\n            'high_limit': 30.0,\n        }]\n    )\n\n    return LaunchDescription([\n        keyboard_vel_controller_node,\n    ])\n\n(cached)"}
[2026-06-02T11:41:19.814Z] [TOOL_RESULT] {"id":"call_01_QAG8TbeNv9AztgguvPAT8316","name":"read_file","elapsed_ms":0,"ok":true,"output":"#!/bin/bash\n\necho \"=========================================\"\necho \"Starting Guided Control\"\necho \"=========================================\"\necho \"\"\n\n# 定义一个函数来调用服务，使代码简洁\nset_rate() {\n    local msg_id=$1\n    local rate=$2\n    ros2 service call /mavros/set_message_interval mavros_msgs/srv/MessageInterval \"{message_id: $msg_id, message_rate: $rate}\"\n}\n\n# 提高 local position (ID 32) 频率\nset_rate 32 100\n\n# 提高 imu/data (ID 31) 频率\nset_rate 31 100\n\n# 提高 imu/data_raw (ID 105) 频率\nset_rate 105 100\n\necho \"=========================================\"\necho \"Message intervals set successfully!\"\necho \"=========================================\"\necho \"\"\n\necho \"=========================================\"\necho \"Launching keyboard_vel_controller...\"\necho \"=========================================\"\nsource ~/ros2-ardupilot-mavros-control/install/setup.bash\n\n# Run directly (not through launch) so stdin is the real terminal.\n# Launch doesn't forward keyboard input — use ros2 run + params file instead.\nPARAMS_FILE=\"$HOME/ros2-ardupilot-mavros-control/install/guided_sim/share/guided_sim/params/keyboard_vel_controller.yaml\"\nif [ ! -f \"$PARAMS_FILE\" ]; then\n    # Fallback: try source tree path\n    PARAMS_FILE=\"$HOME/ros2-ardupilot-mavros-control/src/guided_sim/params/keyboard_vel_controller.yaml\"\nfi\nros2 run guided_sim keyboard_vel_controller --ros-args --params-file \"$PARAMS_FILE\"\n(cached)"}
