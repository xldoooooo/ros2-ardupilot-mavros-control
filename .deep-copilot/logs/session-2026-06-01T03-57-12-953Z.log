d keyboard_thread()\n  {\n    printf(\"--Controller Mode--\\n\");\n    while (rclcpp::ok()) {\n      int key = sh_getch();\n      if (key == 27) return;  // Esc\n\n      std::lock_guard<std::mutex> lock(data_mutex);\n      switch (key) {\n        case 119:  // w\n          zt = z + (1.5 * (z < 0.5) + 0.5 * (z >= 0.5));\n          break;\n        case 97:   // a\n          yaw += 0.05;\n          break;\n        case 115:  // s\n          zt = z - 0.5;\n          break;\n        case 100:  // d\n          yaw -= 0.05;\n          break;\n        case 105:  // i\n          xt = x + 0.5;\n          break;\n        case 106:  // j\n          yt = y + 0.5;\n          break;\n        case 107:  // k\n          xt = x - 0.5;\n          break;\n        case 108:  // l\n          yt = y - 0.5;\n          break;\n        default:\n          printf(\"No this command! (Press Esc to exit)\\n\");\n      }\n\n      Eigen::AngleAxisd rotation_vector(yaw, Eigen::Vector3d(0, 0, 1));\n      Eigen::Quaterniond q_mocap(rotation_vector);\n      rx = q_mocap.x();\n      ry = q_mocap.y();\n      rz = q_mocap.z();\n      rw = q_mocap.w();\n    }\n  }\n\n  void timer_callback()\n  {\n    std::lock_guard<std::mutex> lock(data_mutex);\n\n    // Wait for valid position data\n    if (z == -1000) {\n      xt = x; yt = y; zt = z;\n\n      Eigen::Quaterniond quaternion(rw, rx, ry, rz);\n      Eigen::Vector3d eulerAngle = quaternion.matrix().eulerAngles(2, 1, 0);\n      yaw = eulerAngle[0];\n      printf(\"yaw:%f\\n\", yaw);\n      printf(\"--Controller Mode--\\n\");\n    }\n\n    guided_sim::msg::Target msg;\n    msg.x = xt;\n    msg.y = yt;\n    msg.z = zt;\n    msg.rx = rx;\n    msg.ry = ry;\n    msg.rz = rz;\n    msg.rw = rw;\n    msg.state = \"ok\";\n    pub_->publish(msg);\n  }\n\n  rclcpp::Publisher<guided_sim::msg::Target>::SharedPtr pub_;\n  rclcpp::Subscription<geometry_msgs::msg::PoseStamped>::SharedPtr sub_;\n  rclcpp::TimerBase::SharedPtr timer_;\n  std::thread input_thread_;\n};\n\nint main(int argc, char **argv)\n{\n  rclcpp::init(argc, argv);\n  auto node = std::make_shared<KeyboardPoseTalker>();\n  rclcpp::spin(node);\n  rclcpp::shutdown();\n  return 0;\n}\n","path":"src/guided_sim/src/keyboard_pose_talker.cpp"}}
