uble input =  sample ;\n\n    if (fabsf(1 + _a1 + _a2) > __FLT_EPSILON__) {\n        _delay_element_1 = _delay_element_2 = input / (1 + _a1 + _a2);\n\n    } else {\n        _delay_element_1 = _delay_element_2 = input;\n    }\n\n  "}
