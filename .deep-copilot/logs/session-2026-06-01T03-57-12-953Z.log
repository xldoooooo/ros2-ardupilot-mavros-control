[2026-06-01T04:02:29.919Z] [TOOL_CALL] {"id":"call_00_ftir5oXS1PYXG9i8Lsvl1289","name":"write_file","args":{"content":"#include <rclcpp/rclcpp.hpp>\n#include <guided_sim/msg/target.hpp>\n#include <geometry_msgs/msg/pose_stamped.hpp>\n#include <cmath>\n#include <cstdio>\n\nfloat x = 0, y = 0, z = 2;\ngeometry_msgs::msg::PoseStamped pose;\nint i = 0;\n\nclass Talker : public rclcpp::Node\n{\npublic:\n  Talker()\n  : Node(\"talker\")\n  {\n    pub_ = this->create_publisher<guided_sim::msg::Target>(\"target_info\", 1);\n    sub_ = this->create_subscription<geometry_msgs::msg::PoseStamped>(\n      \"mavros/local_position/pose\", 1,\n      std::bind(&Talker::pose_callback, this, std::placeholders::_1));\n\n    timer_ = this->create_wall_timer(\n      std::chrono::milliseconds(50),\n      std::bind(&Talker::timer_callback, this));\n  }\n\nprivate:\n  void pose_callback(const geometry_msgs::msg::PoseStamped::SharedPtr msg)\n  {\n    pose = *msg;\n    x = pose.pose.position.x;\n    y = pose.pose.position.y;\n    z = pose.pose.position.z;\n  }\n\n  void timer_callback()\n  {\n    static float time = 0;\n    static bool first = true;\n\n    guided_sim::msg::Target msg;\n    if (first) {\n      msg.x = 0;\n      msg.y = 0;\n      msg.z = 30;\n      msg.state = \"ok\";\n      pub_->publish(msg);\n      first = false;\n    }\n\n    time += 0.001f;\n    msg.x += 0.5f;\n    msg.y = 100.0f * std::sin(time);\n    pub_->publish(msg);\n    i++;\n  }\n\n  rclcpp::Publisher<guided_sim::msg::Target>::SharedPtr pub_;\n  rclcpp::Subscription<geometry_msgs::msg::PoseStamped>::SharedPtr sub_;\n  rclcpp::TimerBase::SharedPtr timer_;\n};\n\nint main(int argc, char **argv)\n{\n  rclcpp::init(argc, argv);\n  auto node = std::make_shared<Talker>();\n  rclcpp::spin(node);\n  rclcpp::shutdown();\n  return 0;\n}\n","path":"src/guided_sim/src/talker.cpp"}}
