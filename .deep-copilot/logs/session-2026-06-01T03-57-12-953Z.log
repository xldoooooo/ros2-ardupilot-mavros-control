dl;\n    std::cout << \"   translation: \" << std::endl;\n    std::cout << \"       x: \" << P2.x() << std::endl;\n    std::cout << \"       y: \" << P2.y() << std::endl;\n    std::cout << \"       z: \" << P2.z() << std::endl;\n    std::cout << \"   orientation: \" << std::endl;\n    std::cout << \"       x: \" << Q2.x() << std::endl;\n    std::cout << \"       y: \" << Q2.y() << std::endl;\n    std::cout << \"       z: \" << Q2.z() << std::endl;\n    std::cout << \"       w: \" << Q2.w() << std::endl;\n  }\n\n  rclcpp::Subscription<tf2_msgs::msg::TFMessage>::SharedPtr tf_sub_;\n  rclcpp::TimerBase::SharedPtr timer_;\n  geometry_msgs::msg::PoseStamped pose_;\n};\n\nint main(int argc, char **argv)\n{\n  rclcpp::init(argc, argv);\n  auto node = std::make_shared<ReadTf>();\n  rclcpp::spin(node);\n  rclcpp::shutdown();\n  return 0;\n}\n","path":"src/guided_sim/src/read_tf.cpp"}}
