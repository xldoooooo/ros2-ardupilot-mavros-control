<?xml version="1.0"?>
<robot name="quadcopter">
  <material name="body"><color rgba="0.25 0.25 0.25 1"/></material>
  <material name="arm"><color rgba="0.45 0.45 0.45 1"/></material>
  <material name="dot"><color rgba="0 0.85 0 1"/></material>

  <link name="base_link">
    <visual><geometry><box size="0.10 0.10 0.04"/></geometry><material name="body"/></visual>
  </link>

  <joint name="a1" type="fixed"><parent link="base_link"/><child link="a1"/><origin xyz="0.05 0.05 0" rpy="0 0 0.7854"/></joint>
  <link name="a1"><visual><geometry><box size="0.18 0.02 0.012"/></geometry><material name="arm"/></visual></link>

  <joint name="a2" type="fixed"><parent link="base_link"/><child link="a2"/><origin xyz="0.05 -0.05 0" rpy="0 0 -0.7854"/></joint>
  <link name="a2"><visual><geometry><box size="0.18 0.02 0.012"/></geometry><material name="arm"/></visual></link>

  <joint name="a3" type="fixed"><parent link="base_link"/><child link="a3"/><origin xyz="-0.05 -0.05 0" rpy="0 0 0.7854"/></joint>
  <link name="a3"><visual><geometry><box size="0.18 0.02 0.012"/></geometry><material name="arm"/></visual></link>

  <joint name="a4" type="fixed"><parent link="base_link"/><child link="a4"/><origin xyz="-0.05 0.05 0" rpy="0 0 -0.7854"/></joint>
  <link name="a4"><visual><geometry><box size="0.18 0.02 0.012"/></geometry><material name="arm"/></visual></link>

  <joint name="fd" type="fixed"><parent link="base_link"/><child link="fd"/><origin xyz="0.10 0 0.03"/></joint>
  <link name="fd"><visual><geometry><sphere radius="0.02"/></geometry><material name="dot"/></visual></link>
</robot>
